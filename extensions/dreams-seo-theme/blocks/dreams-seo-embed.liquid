{% comment %}
  Dreams SEO — Otimizações fixas de performance.
  Nenhuma configuração necessária — tudo aplicado automaticamente.
{% endcomment %}

{% comment %} ── 1. Resource hints ── {% endcomment %}
<link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
<link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
<link rel="dns-prefetch" href="https://cdn.shopify.com">
<link rel="dns-prefetch" href="https://www.google-analytics.com">
<link rel="dns-prefetch" href="https://connect.facebook.net">

{% comment %} ── 2. Preload imagem principal ── {% endcomment %}
{% if product.featured_image %}
  <link rel="preload" as="image" href="{{ product.featured_image | image_url: width: 800, format: 'webp' }}" fetchpriority="high">
{% elsif collection.image %}
  <link rel="preload" as="image" href="{{ collection.image | image_url: width: 800, format: 'webp' }}" fetchpriority="high">
{% endif %}

{% comment %} ── 3. Font-display: swap ── {% endcomment %}
<style>@font-face { font-display: swap !important; }</style>

{% comment %} ── 4. Schema JSON-LD ── {% endcomment %}
{% if template.name == 'product' and product %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": {{ product.title | json }},
    "description": {{ product.description | strip_html | truncate: 300 | json }},
    "image": "{{ product.featured_image | image_url: width: 800 }}",
    "url": "{{ shop.url }}{{ product.url }}",
    "brand": { "@type": "Brand", "name": {{ shop.name | json }} },
    "offers": {
      "@type": "Offer",
      "priceCurrency": {{ cart.currency.iso_code | json }},
      "price": "{{ product.price | money_without_currency }}",
      "availability": "{% if product.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
      "url": "{{ shop.url }}{{ product.url }}"
    }
  }
  </script>
{% endif %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": {{ shop.name | json }},
  "url": "{{ shop.url }}"
}
</script>

{% comment %} ── 5. Lazy load imagens + WebP (ignora carrinho/checkout) ── {% endcomment %}
{% unless template.name == 'cart' or template.name == 'checkout' %}
<script defer>
document.addEventListener('DOMContentLoaded', function() {
  var IMG_MARGIN = 900;
  var VID_MARGIN = 1500;
  var foldLimit = (window.innerHeight || 800) * 1.2;

  function playVideo(v) {
    v.preload = 'auto';
    if (typeof v.load === 'function') v.load();
    if (v.hasAttribute('autoplay')) {
      var p = v.play(); if (p && p.catch) p.catch(function(){});
    }
  }

  function loadEl(el) {
    if (el.dataset.dsLoaded) return;
    el.dataset.dsLoaded = '1';
    if (el.dataset.src) {
      el.src = el.dataset.src;
      if (el.tagName === 'VIDEO' && typeof el.load === 'function') el.load();
    }
    if (el.tagName === 'VIDEO') playVideo(el);
    if (el.tagName === 'IMG') { el.loading = 'eager'; el.decoding = 'async'; }
  }

  var imgs = [], vids = [];
  document.querySelectorAll('img, video, iframe').forEach(function(el) {
    var top = el.getBoundingClientRect().top;
    var autoplay = el.tagName === 'VIDEO' && el.hasAttribute('autoplay');
    if (top < foldLimit || autoplay) {
      if (el.tagName === 'IMG') { el.loading = 'eager'; el.fetchPriority = 'high'; }
      if (el.tagName === 'VIDEO') playVideo(el);
    } else {
      if (el.tagName === 'IMG') el.loading = 'lazy';
      el.decoding = 'async';
      (el.tagName === 'VIDEO' ? vids : imgs).push(el);
    }
  });

  if ('IntersectionObserver' in window) {
    function makeObserver(list, margin) {
      if (!list.length) return;
      var obs = new IntersectionObserver(function(entries) {
        entries.forEach(function(e) { if (e.isIntersecting) { loadEl(e.target); obs.unobserve(e.target); } });
      }, { rootMargin: margin + 'px 0px', threshold: 0.01 });
      list.forEach(function(el) { obs.observe(el); });
    }
    makeObserver(imgs, IMG_MARGIN);
    makeObserver(vids, VID_MARGIN);
  }

  var all = imgs.concat(vids);
  setTimeout(function() { all.forEach(loadEl); }, 1500);
  if ('requestIdleCallback' in window) requestIdleCallback(function() { all.forEach(loadEl); }, { timeout: 3000 });
});
</script>

{% comment %} ── WebP automático via CDN Shopify ── {% endcomment %}
<script defer>
document.addEventListener('DOMContentLoaded', function() {
  document.querySelectorAll('img[src*="cdn.shopify"]').forEach(function(img) {
    var src = img.getAttribute('src') || '';
    if (!src.includes('format=webp') && !src.includes('.svg')) {
      img.src = src + (src.includes('?') ? '&' : '?') + 'format=webp';
    }
  });
});
</script>
{% endunless %}

{% comment %} ── 6. Scripts customizados do app ── {% endcomment %}
{% assign ds_scripts = shop.metafields.dreams_seo.scripts.value %}
{% if ds_scripts != blank %}
  {% for item in ds_scripts %}
    {% if item.enabled and item.placement == 'head' %}{{ item.content }}{% endif %}
  {% endfor %}
  <script defer>
  document.addEventListener('DOMContentLoaded', function() {
    var scripts = {{ ds_scripts | json }};
    if (!Array.isArray(scripts)) return;
    scripts.forEach(function(item) {
      if (!item.enabled || item.placement === 'head') return;
      var div = document.createElement('div');
      div.innerHTML = item.content;
      Array.from(div.childNodes).forEach(function(node) {
        if (node.nodeName === 'SCRIPT') {
          var s = document.createElement('script');
          if (node.src) s.src = node.src;
          if (node.type) s.type = node.type;
          if (node.textContent) s.textContent = node.textContent;
          s.async = true;
        } else if (node.nodeType === 1) {
          var target = item.placement === 'body_start' ? document.body.firstChild : null;
          if (target) document.body.insertBefore(node, target);
          else document.body.appendChild(node);
        }
      });
    });
  });
  </script>
{% endif %}

{% schema %}
{
  "name": "Dreams SEO",
  "target": "head",
  "settings": [
    {
      "type": "paragraph",
      "content": "Otimizações aplicadas automaticamente. Nenhuma configuração necessária."
    }
  ]
}
{% endschema %}
