{% comment %}
  Dreams SEO — Theme App Extension
  Lê configurações do app via shop.metafields.dreams_seo.config (sincronizado pelo admin)
{% endcomment %}

{% liquid
  assign ds_lazy = block.settings.lazy_load_enabled
  assign ds_delay = block.settings.delay_js_enabled
  assign ds_trigger = 'scroll'
  assign ds_hints = block.settings.resource_hints_level
  assign ds_schema = block.settings.schema_enabled
  assign ds_font = block.settings.font_optimization
  assign ds_preload = true
  assign ds_prefetch = false
  assign ds_dns = true
  assign ds_preconnect = true
  assign ds_webp = true

  assign cfg = shop.metafields.dreams_seo.config.value
  if cfg != blank
    if cfg.lazy_load_enabled != nil
      assign ds_lazy = cfg.lazy_load_enabled
    endif
    if cfg.delay_js_enabled != nil
      assign ds_delay = cfg.delay_js_enabled
    endif
    if cfg.delay_js_trigger != blank
      assign ds_trigger = cfg.delay_js_trigger
    endif
    if cfg.resource_hints_level != nil
      assign ds_hints = cfg.resource_hints_level
    endif
    if cfg.schema_enabled != nil
      assign ds_schema = cfg.schema_enabled
    endif
    if cfg.font_optimization != nil
      assign ds_font = cfg.font_optimization
    endif
    if cfg.preload_enabled != nil
      assign ds_preload = cfg.preload_enabled
    endif
    if cfg.prefetch_enabled != nil
      assign ds_prefetch = cfg.prefetch_enabled
    endif
    if cfg.dns_prefetch_enabled != nil
      assign ds_dns = cfg.dns_prefetch_enabled
    endif
    if cfg.preconnect_enabled != nil
      assign ds_preconnect = cfg.preconnect_enabled
    endif
    if cfg.webp_enabled != nil
      assign ds_webp = cfg.webp_enabled
    endif
  endif
%}

{% if ds_preconnect or ds_dns %}
  {% if ds_preconnect %}
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
    <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
  {% endif %}
  {% if ds_dns %}
    <link rel="dns-prefetch" href="https://cdn.shopify.com">
    <link rel="dns-prefetch" href="https://www.google-analytics.com">
    <link rel="dns-prefetch" href="https://connect.facebook.net">
  {% endif %}
{% endif %}

{% if ds_hints >= 2 and ds_preload %}
  {% if product.featured_image %}
    <link rel="preload" as="image" href="{{ product.featured_image | image_url: width: 800, format: 'webp' }}">
  {% elsif collection.image %}
    <link rel="preload" as="image" href="{{ collection.image | image_url: width: 800, format: 'webp' }}">
  {% endif %}
{% endif %}

{% if ds_prefetch and ds_hints >= 3 %}
  <link rel="prefetch" href="{{ routes.root_url }}">
{% endif %}

{% if ds_font %}
  <style>
    @font-face { font-display: swap !important; }
  </style>
{% endif %}

{% if ds_schema %}
  {% if template.name == 'product' and product %}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Product",
      "name": {{ product.title | json }},
      "description": {{ product.description | strip_html | truncate: 300 | json }},
      "image": "{{ product.featured_image | image_url: width: 800 }}",
      "url": "{{ shop.url }}{{ product.url }}",
      "brand": { "@type": "Brand", "name": {{ shop.name | json }} },
      "offers": {
        "@type": "Offer",
        "priceCurrency": {{ cart.currency.iso_code | json }},
        "price": "{{ product.price | money_without_currency }}",
        "availability": "{% if product.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
        "url": "{{ shop.url }}{{ product.url }}"
      }
    }
    </script>
  {% endif %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": {{ shop.name | json }},
    "url": "{{ shop.url }}"
  }
  </script>
{% endif %}

{% if ds_lazy %}
  <script defer>
    document.addEventListener('DOMContentLoaded', function() {
      document.querySelectorAll('img:not([loading])').forEach(function(img) {
        img.loading = 'lazy';
        img.decoding = 'async';
      });
    });
  </script>
{% endif %}

{% if ds_webp %}
  <script defer>
    document.addEventListener('DOMContentLoaded', function() {
      document.querySelectorAll('img[src*="cdn.shopify"]').forEach(function(img) {
        var src = img.getAttribute('src') || '';
        if (src.indexOf('format=webp') === -1 && src.indexOf('.svg') === -1) {
          var sep = src.indexOf('?') > -1 ? '&' : '?';
          img.src = src + sep + 'format=webp';
        }
      });
    });
  </script>
{% endif %}

{% if ds_delay and ds_trigger != 'disabled' %}
  <script defer>
    (function() {
      var triggered = false;
      var patterns = [
        'google-analytics.com', 'googletagmanager.com', 'connect.facebook.net',
        'hotjar.com', 'clarity.ms', 'analytics.tiktok.com', 'pinimg.com'
      ];
      var trigger = {{ ds_trigger | json }};
      function loadDelayedScripts() {
        if (triggered) return;
        triggered = true;
        document.querySelectorAll('script[type=\"text/dreams-delay\"]').forEach(function(s) {
          var n = document.createElement('script');
          n.src = s.getAttribute('data-src') || '';
          n.async = true;
          document.head.appendChild(n);
        });
      }
      if (trigger === 'scroll') {
        window.addEventListener('scroll', loadDelayedScripts, { once: true, passive: true });
      } else if (trigger === 'click') {
        window.addEventListener('click', loadDelayedScripts, { once: true });
      } else {
        ['scroll', 'click', 'touchstart', 'mousemove'].forEach(function(evt) {
          window.addEventListener(evt, loadDelayedScripts, { once: true, passive: true });
        });
      }
      setTimeout(loadDelayedScripts, 8000);
    })();
  </script>
{% endif %}

{% schema %}
{
  "name": "Dreams SEO",
  "target": "head",
  "settings": [
    {
      "type": "paragraph",
      "content": "Configure pelo app Dreams SEO → Otimização. As configs do app sobrescrevem estas opções."
    },
    {
      "type": "checkbox",
      "id": "lazy_load_enabled",
      "label": "Lazy Load (fallback)",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "delay_js_enabled",
      "label": "Delay JavaScript (fallback)",
      "default": false
    },
    {
      "type": "range",
      "id": "resource_hints_level",
      "label": "Nível de cache (fallback)",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "checkbox",
      "id": "schema_enabled",
      "label": "Schema JSON-LD (fallback)",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "font_optimization",
      "label": "Otimização de fontes (fallback)",
      "default": true
    }
  ]
}
{% endschema %}
